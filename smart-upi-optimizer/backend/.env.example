# ============================================================
# Smart UPI Routing Optimizer — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://upi_user:upi_secret@localhost:5432/upi_optimizer

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-me-in-production

# ── Application ──────────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=info

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Railway.app (Production) ─────────────────────────────────
# RAILWAY_DATABASE_URL=postgresql://user:pass@host:port/dbname
# RAILWAY_SECRET_KEY=your-production-secret-key
